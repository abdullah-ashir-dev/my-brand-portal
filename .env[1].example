# ============================================================
# FILE: .env  (in your project ROOT folder, next to package.json)
# PURPOSE: Store your secret Firebase keys safely
# ⚠️  IMPORTANT: NEVER push this file to GitHub!
#     Add .env to your .gitignore file
# ============================================================
# 📋 HOW TO FILL THESE:
#   1. Go to https://console.firebase.google.com
#   2. Click your project → ⚙️ Project Settings
#   3. Scroll to "Your apps" → click the web app (</>)
#   4. Copy each value from the firebaseConfig object
# ============================================================

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
